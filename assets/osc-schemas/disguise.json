      "label": "Cue Recall",
      "address": "/d3/showcontrol/cue",
      "args": [
        { "name": "cue_path", "type": "s", "default": "" }
      ]
    },
    {
      "name": "layer_opacity",
      "label": "Layer Opacity",
      "address": "/d3/layer/opacity",
      "args": [
        { "name": "layer_name", "type": "s", "default": "" },
        { "name": "opacity", "type": "f", "default": 1.0, "min": 0, "max": 1 }
      ]
    },
    {
      "name": "note_trigger",
      "label": "Wyślij notatkę",
      "address": "/d3/showcontrol/note",
      "args": [
        { "name": "note_text", "type": "s", "default": "" }
      ]
    }
