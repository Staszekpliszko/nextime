      "label": "Transport Play",
      "address": "/d3/showcontrol/play",
      "args": []
    },
    {
      "name": "transport_stop",
      "label": "Transport Stop",
      "address": "/d3/showcontrol/stop",
      "args": []
    },
    {
      "name": "transport_goto",
      "label": "Transport Go To (sekcja + czas)",
      "address": "/d3/showcontrol/goto",
      "args": [
        { "name": "section", "type": "s", "default": "" },
        { "name": "time_seconds", "type": "f", "default": 0, "min": 0 }
      ]
    },
    {
